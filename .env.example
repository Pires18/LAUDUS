# ────────────────────────────────────────────────────────
# Firebase Config
# ────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIzaSyAVqN1pcxvcgxmZRt_-dCJCdg0Y4XK2Ixk
VITE_FIREBASE_AUTH_DOMAIN=antigravity-laudus.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=antigravity-laudus
VITE_FIREBASE_STORAGE_BUCKET=antigravity-laudus.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=542081396849
VITE_FIREBASE_APP_ID=1:542081396849:web:f80667d559e5a30b36abd0

# ────────────────────────────────────────────────────────
# Google AI / Gemini (proxy server-side)
# Chave usada pelo /api/gemini quando o cliente não envia uma.
# Em produção, configure como GOOGLE_API_KEY nas env vars da Vercel.
# ────────────────────────────────────────────────────────
GOOGLE_API_KEY=

# ────────────────────────────────────────────────────────
# Firebase Admin SDK (SERVIDOR — funções api/*)
# Usado por api/_firebase, verificação de token e webhooks. NUNCA no browser.
# Obtenha em: Firebase Console > Project Settings > Service accounts >
# Generate new private key. A private key vai entre aspas com \n literais.
# ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=antigravity-laudus
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ────────────────────────────────────────────────────────
# Pagamentos AbacatePay + CRON (SERVIDOR — opcional)
# ────────────────────────────────────────────────────────
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=
CRON_SECRET=

# ────────────────────────────────────────────────────────
# Admin do Sistema
# UID e e-mail do usuário administrador.
# Obtenha o UID no Firebase Console > Authentication > Users.
# ────────────────────────────────────────────────────────
VITE_ADMIN_UID=
VITE_ADMIN_EMAIL=

# ────────────────────────────────────────────────────────
# Ambiente
# ────────────────────────────────────────────────────────
VITE_ENVIRONMENT=development
VITE_LOG_LEVEL=info

# ────────────────────────────────────────────────────────
# Sentry (monitoramento de erros) — opcional
# Crie um projeto em sentry.io e cole o DSN público aqui.
# Vazio = desativado (nada é enviado).
# ────────────────────────────────────────────────────────
VITE_SENTRY_DSN=

# ────────────────────────────────────────────────────────
# Orthanc PACS / DICOM (configuração local de desenvolvimento)
# Em produção, configure via Interface de Settings no app.
# ────────────────────────────────────────────────────────
# Diretório da Worklist DICOM (deixe vazio para configurar pelo app)
VITE_ORTHANC_WORKLIST_DIR=
# Caminho do executável Python
VITE_PYTHON_PATH=python3
