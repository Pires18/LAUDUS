# ────────────────────────────────────────────────────────
# Firebase Config
# ────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIzaSyAVqN1pcxvcgxmZRt_-dCJCdg0Y4XK2Ixk
VITE_FIREBASE_AUTH_DOMAIN=antigravity-laudus.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=antigravity-laudus
VITE_FIREBASE_STORAGE_BUCKET=antigravity-laudus.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=542081396849
VITE_FIREBASE_APP_ID=1:542081396849:web:f80667d559e5a30b36abd0

# ────────────────────────────────────────────────────────
# Google AI / Gemini (proxy server-side)
# Chave usada pelo /api/gemini quando o cliente não envia uma.
# Em produção, configure como GOOGLE_API_KEY nas env vars da Vercel.
# ────────────────────────────────────────────────────────
GOOGLE_API_KEY=sua-chave-aqui

# ────────────────────────────────────────────────────────
# Firebase Admin SDK (SERVIDOR — funções api/*)
# Usado por api/_firebase, verificação de token e webhooks. NUNCA no browser.
# Obtenha em: Firebase Console > Project Settings > Service accounts >
# Generate new private key. A private key vai entre aspas com \n literais.
# ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=antigravity-laudus
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@antigravity-laudus.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

# ────────────────────────────────────────────────────────
# Pagamentos AbacatePay + CRON (SERVIDOR — opcional)
# ────────────────────────────────────────────────────────
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=
CRON_SECRET=

# ────────────────────────────────────────────────────────
# Rate limit distribuído (SERVIDOR — opcional)
# Vercel KV ou Upstash Redis (mesma API REST). Sem isso, o rate limit do
# /api/gemini cai para memória local por instância (funciona, mas não é
# compartilhado entre instâncias Edge).
# ────────────────────────────────────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ────────────────────────────────────────────────────────
# Admin do Sistema
# UID e e-mail do usuário administrador.
# Obtenha o UID no Firebase Console > Authentication > Users.
# ────────────────────────────────────────────────────────
VITE_ADMIN_UID=
VITE_ADMIN_EMAIL=

# ────────────────────────────────────────────────────────
# Ambiente
# ────────────────────────────────────────────────────────
VITE_ENVIRONMENT=development
# URL pública para testes locais de webhook (ex: gerada por ngrok http 5173 ou Tailscale Funnel)
VITE_PUBLIC_URL=https://buckshot-cheating-afar.ngrok-free.dev

# ────────────────────────────────────────────────────────
# Sentry (monitoramento de erros) — opcional
# Crie um projeto em sentry.io e cole o DSN público aqui.
# Vazio = desativado (nada é enviado).
# ────────────────────────────────────────────────────────
VITE_SENTRY_DSN=

# ────────────────────────────────────────────────────────
# Orthanc PACS / DICOM (configuração local de desenvolvimento)
# Em produção, configure via Interface de Settings no app.
# ────────────────────────────────────────────────────────
# Diretório da Worklist DICOM (deixe vazio para configurar pelo app)
VITE_ORTHANC_WORKLIST_DIR=C:\OrthancServer\db\WorklistsDatabase\
# Caminho do executável Python
VITE_PYTHON_PATH=python
# Sufixos de host que os proxies server-side (api/orthanc-proxy, api/worklist)
# podem alcançar na nuvem (anti-SSRF). Default: .ts.net (Tailscale Funnel).
# Só configure se usar domínio próprio para o Agente. Ex.: .ts.net,.suaclinica.com
ORTHANC_PROXY_ALLOWED_HOST_SUFFIXES=.ts.net

# ────────────────────────────────────────────────────────
# Agente Local (scripts/agent.js)
# ────────────────────────────────────────────────────────
# Porta para rodar o servidor do agente local (padrão: 3000)
PORT=3000
# Segredo compartilhado obrigatório para requisições de escrita/proxy no agente
LAUDUS_AGENT_SECRET=
# Lista de hosts permitidos para proxy reversivo (ex: localhost,127.0.0.1)
LAUDUS_ALLOWED_HOSTS=
# Diretório local padrão para gravação de worklists no agente
LAUDUS_WORKLIST_DIR=

# ────────────────────────────────────────────────────────
# Provisionamento de VM PACS (SERVIDOR — opcional, api/pacs-provision.ts)
# Sem GCP_SA_KEY + TAILSCALE_API_KEY + TAILSCALE_TS_NET configurados (ou com
# PACS_MOCK=1), o endpoint cai em modo mock — devolve dados simulados, sem
# provisionar VM real. Use isso para testar o fluxo sem custo de nuvem.
# ────────────────────────────────────────────────────────
# Força modo mock mesmo com credenciais GCP configuradas (1 = mock)
PACS_MOCK=
# Google Cloud — projeto e zona onde as VMs de PACS são criadas
GCP_PROJECT_ID=antigravity-laudus
GCP_ZONE=southamerica-east1-c
# JSON completo (uma linha) da service account com permissão de Compute Admin
GCP_SA_KEY=
# Nome/família da imagem "dourada" do PACS (padrão: projects/{project}/global/images/family/laudus-pacs)
PACS_IMAGE=
# URL base onde os scripts de setup do agente (pacs-vm-setup.sh etc.) são servidos
PACS_SCRIPTS_URL=
# Tailscale — chave de API para gerar auth-keys pré-autorizadas por VM
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=
# Domínio da tailnet usado para montar a URL do agente de cada VM (https://{vm}.{TAILSCALE_TS_NET})
TAILSCALE_TS_NET=
# VM compartilhada (fallback dos planos Starter/Pro) + segredo admin correspondente
PACS_SHARED_AGENT_URL=
PACS_ADMIN_SECRET=
