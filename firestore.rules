rules_version = '2';

// ============================================================================
// LAUD.US — Regras de Segurança do Firestore (RBAC)
//
// Modelo de dados:
//   • Coleções por usuário:   users/{uid}/{collection}/{doc}
//       (templates, exams, patients, clinics, appointments, settings, ...)
//   • Coleções globais (raiz): users, subscriptions, saas_plans,
//       audit_logs, support_tickets, transactions, global_config, system
//
// Princípios:
//   • Todo acesso exige autenticação.
//   • Cada usuário é dono total da sua subárvore users/{uid}/**.
//   • Admins (super admin por e-mail OU role == 'admin') administram as
//     coleções globais de usuários e planos — corrige o "erro de permissão"
//     ao editar usuários/assinaturas pelo painel admin.
//   • Webhooks de pagamento usam o Admin SDK no servidor e ignoram estas
//     regras (acesso privilegiado), portanto não precisam de exceções aqui.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'matheuskpires@gmail.com';
    }

    // Lê o role do próprio documento do usuário (users/{uid}).
    function isAdmin() {
      return isSuperAdmin()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Campos que definem privilégio/cota/assinatura — SOMENTE admin (ou
    // Admin SDK no servidor) pode alterá-los. Impede que um usuário comum
    // se auto-promova a admin ou infle a própria cota.
    function touchesProtectedUserFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role', 'motorProEnabled', 'reportsQuota', 'clinicsQuota',
        'subscriptionStatus', 'subscriptionId', 'licenseExpiresAt',
        'active', 'addons', 'createdAt', 'email'
      ]);
    }

    // O contador de uso mensal só pode crescer pelo cliente; o reset (zerar)
    // é feito exclusivamente pelo CRON via Admin SDK.
    function usageCounterOnlyIncreases() {
      return !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['reportsUsedThisMonth'])
        || request.resource.data.reportsUsedThisMonth >= resource.data.get('reportsUsedThisMonth', 0);
    }

    // ---- Coleção de usuários + subárvore por usuário ----------------------
    match /users/{userId} {
      // O próprio usuário lê seu doc; admin lê qualquer usuário.
      allow read: if isOwner(userId) || isAdmin();
      // Auto-provisionamento (trial) não pode nascer com privilégio de admin
      // nem cotas acima do padrão. O Super Admin cai em isAdmin() (por e-mail).
      allow create: if isAdmin()
        || (isOwner(userId)
            && request.resource.data.get('role', 'medico') != 'admin'
            && request.resource.data.get('motorProEnabled', false) == false
            && request.resource.data.get('reportsQuota', 0) <= 100
            && request.resource.data.get('clinicsQuota', 0) <= 5);
      // Dono atualiza o próprio perfil (nome, foto, lastLogin, uso), mas
      // NUNCA os campos de privilégio/cota. Admin gerencia tudo.
      allow update: if isAdmin()
        || (isOwner(userId)
            && !touchesProtectedUserFields()
            && usageCounterOnlyIncreases());
      allow delete: if isOwner(userId) || isAdmin();

      // Máscaras de laudo: o dono e o admin acessam as suas; as máscaras
      // "do sistema" (subárvore de um admin) são legíveis por todos os
      // usuários autenticados. Máscaras pessoais deixam de ser públicas.
      match /templates/{templateId} {
        allow read: if isOwner(userId) || isAdmin()
          || (isSignedIn()
              && get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin');
        allow write: if isOwner(userId) || isAdmin();
      }

      // Demais dados da subárvore do usuário: dono ou admin.
      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ---- Assinaturas / planos do cliente ----------------------------------
    match /subscriptions/{subId} {
      // Dono lê a própria assinatura; admin lê/gerencia todas.
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      // Criação/exclusão só por admin (ou Admin SDK nos webhooks).
      allow create, delete: if isAdmin();
      // Atualização: admin faz tudo; o dono só pode incrementar o contador de
      // uso mensal (espelho do doc do usuário) — corrige a transação de quota
      // que antes falhava por completo (bug D2). Nenhum outro campo é editável.
      allow update: if isAdmin()
        || (isSignedIn()
            && resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['reportsUsedThisMonth', 'updatedAt'])
            && request.resource.data.get('reportsUsedThisMonth', 0)
                 >= resource.data.get('reportsUsedThisMonth', 0));
    }

    // ---- Catálogo de planos SaaS ------------------------------------------
    match /saas_plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---- Logs de auditoria -------------------------------------------------
    match /audit_logs/{logId} {
      // Usuário registra ações em nome próprio (sem forjar autoria); admin lê.
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ---- Tickets de suporte ------------------------------------------------
    match /support_tickets/{ticketId} {
      // Usuário cria/lê/atualiza o próprio ticket; admin gerencia todos.
      allow read, update: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();

      // Mensagens dentro do ticket: apenas o dono do ticket ou admin.
      match /{document=**} {
        allow read, write: if isAdmin()
          || (isSignedIn()
              && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid);
      }
    }

    // ---- Transações financeiras (sensível) --------------------------------
    match /transactions/{txId} {
      // Admin lê tudo; o dono lê apenas as próprias transações (histórico de
      // pagamentos no painel do usuário). A consulta precisa filtrar por userId.
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false; // somente Admin SDK (webhooks) escreve
    }

    // ---- Configuração global e mensagens de sistema -----------------------
    match /global_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---- Métricas diárias agregadas (telemetria) --------------------------
    // Escritas SOMENTE pelo CRON via Admin SDK (collection-group sobre ai_usage);
    // o painel admin apenas lê.
    match /metrics_daily/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---- Bloqueio padrão ---------------------------------------------------
    // Qualquer caminho não declarado acima é negado por omissão.
  }
}
