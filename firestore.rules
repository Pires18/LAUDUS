rules_version = '2';

// ============================================================================
// LAUD.US — Regras de Segurança do Firestore (RBAC)
//
// Modelo de dados:
//   • Coleções por usuário:   users/{uid}/{collection}/{doc}
//       (templates, exams, patients, clinics, appointments, settings, ...)
//   • Coleções globais (raiz): users, subscriptions, saas_plans,
//       audit_logs, support_tickets, transactions, global_config, system
//
// Princípios:
//   • Todo acesso exige autenticação.
//   • Cada usuário é dono total da sua subárvore users/{uid}/**.
//   • Admins (super admin por e-mail OU role == 'admin') administram as
//     coleções globais de usuários e planos — corrige o "erro de permissão"
//     ao editar usuários/assinaturas pelo painel admin.
//   • Webhooks de pagamento usam o Admin SDK no servidor e ignoram estas
//     regras (acesso privilegiado), portanto não precisam de exceções aqui.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'matheuskpires@gmail.com';
    }

    // Lê o role do próprio documento do usuário (users/{uid}).
    function isAdmin() {
      return isSuperAdmin()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---- Membership de clínica (equipe multiusuário) -----------------------
    // Doc id determinístico `${ownerId}_${clinicId}_${memberUid}` em
    // clinic_memberships/ — permite `exists()`/`get()` sem precisar de query.
    // Enquanto nenhum convite for emitido para uma clínica, estas funções
    // retornam false para todo mundo exceto o dono/admin (comportamento
    // idêntico ao anterior a esta mudança).
    function clinicMembershipId(ownerId, clinicId) {
      return ownerId + '_' + clinicId + '_' + request.auth.uid;
    }

    function hasClinicAccess(ownerId, clinicId) {
      return isSignedIn() && clinicId is string && clinicId.size() > 0
        && exists(/databases/$(database)/documents/clinic_memberships/$(clinicMembershipId(ownerId, clinicId)));
    }

    function hasClinicWriteAccess(ownerId, clinicId) {
      return hasClinicAccess(ownerId, clinicId)
        && get(/databases/$(database)/documents/clinic_memberships/$(clinicMembershipId(ownerId, clinicId))).data.role != 'viewer';
    }

    // Campos que definem privilégio/cota/assinatura — SOMENTE admin (ou
    // Admin SDK no servidor) pode alterá-los. Impede que um usuário comum
    // se auto-promova a admin ou infle a própria cota.
    function touchesProtectedUserFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role', 'motorProEnabled', 'reportsQuota', 'clinicsQuota',
        'subscriptionStatus', 'subscriptionId', 'licenseExpiresAt',
        'active', 'addons', 'createdAt', 'email'
      ]);
    }

    // O contador de uso mensal só pode crescer pelo cliente; o reset (zerar)
    // é feito exclusivamente pelo CRON via Admin SDK.
    function usageCounterOnlyIncreases() {
      return !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['reportsUsedThisMonth'])
        || request.resource.data.reportsUsedThisMonth >= resource.data.get('reportsUsedThisMonth', 0);
    }

    // ---- Coleção de usuários + subárvore por usuário ----------------------
    match /users/{userId} {
      // O próprio usuário lê seu doc; admin lê qualquer usuário.
      allow read: if isOwner(userId) || isAdmin();
      // Auto-provisionamento (trial) não pode nascer com privilégio de admin
      // nem cotas acima do padrão. O Super Admin cai em isAdmin() (por e-mail).
      allow create: if isAdmin()
        || (isOwner(userId)
            && request.resource.data.get('role', 'medico') != 'admin'
            && request.resource.data.get('motorProEnabled', false) == false
            && request.resource.data.get('reportsQuota', 0) <= 100
            && request.resource.data.get('clinicsQuota', 0) <= 5);
      // Dono atualiza o próprio perfil (nome, foto, lastLogin, uso), mas
      // NUNCA os campos de privilégio/cota. Admin gerencia tudo.
      allow update: if isAdmin()
        || (isOwner(userId)
            && !touchesProtectedUserFields()
            && usageCounterOnlyIncreases());
      allow delete: if isOwner(userId) || isAdmin();

      // Máscaras de laudo: o dono e o admin acessam as suas; as máscaras
      // "do sistema" (subárvore de um admin) são legíveis por todos os
      // usuários autenticados. Máscaras pessoais deixam de ser públicas.
      match /templates/{templateId} {
        allow read: if isOwner(userId) || isAdmin()
          || (isSignedIn()
              && get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin');
        allow write: if isOwner(userId) || isAdmin();
      }

      // Clínicas: dono/admin gerenciam; membro convidado (qualquer papel) só lê.
      match /clinics/{clinicId} {
        allow read: if isOwner(userId) || isAdmin() || hasClinicAccess(userId, clinicId);
        allow write: if isOwner(userId) || isAdmin();
      }

      // Pacientes, exames e agenda: dono/admin têm acesso total; membro da
      // clínica (papel != viewer) lê e escreve; viewer só lê. Documentos sem
      // clinicId (registros antigos/"todas as clínicas") continuam
      // acessíveis apenas ao dono/admin — hasClinicAccess retorna false.
      // Nota: `update` de membro (não dono/admin) exige, além de acesso de
      // escrita à clínica ATUAL do documento, que o `clinicId` NÃO mude —
      // sem isso, um editor conseguiria reatribuir o registro para outra
      // clínica (inclusive uma à qual não tem acesso), escapando do
      // isolamento por clínica. `delete` dispensa essa checagem (não há
      // request.resource em delete).
      match /patients/{patientId} {
        allow read: if isOwner(userId) || isAdmin() || hasClinicAccess(userId, resource.data.clinicId);
        allow create: if isOwner(userId) || isAdmin() || hasClinicWriteAccess(userId, request.resource.data.clinicId);
        allow update: if isOwner(userId) || isAdmin()
          || (hasClinicWriteAccess(userId, resource.data.clinicId) && request.resource.data.clinicId == resource.data.clinicId);
        allow delete: if isOwner(userId) || isAdmin() || hasClinicWriteAccess(userId, resource.data.clinicId);
      }
      match /exams/{examId} {
        allow read: if isOwner(userId) || isAdmin() || hasClinicAccess(userId, resource.data.clinicId);
        allow create: if isOwner(userId) || isAdmin() || hasClinicWriteAccess(userId, request.resource.data.clinicId);
        allow update: if isOwner(userId) || isAdmin()
          || (hasClinicWriteAccess(userId, resource.data.clinicId) && request.resource.data.clinicId == resource.data.clinicId);
        allow delete: if isOwner(userId) || isAdmin() || hasClinicWriteAccess(userId, resource.data.clinicId);
      }
      match /appointments/{apptId} {
        allow read: if isOwner(userId) || isAdmin() || hasClinicAccess(userId, resource.data.clinicId);
        allow create: if isOwner(userId) || isAdmin() || hasClinicWriteAccess(userId, request.resource.data.clinicId);
        allow update: if isOwner(userId) || isAdmin()
          || (hasClinicWriteAccess(userId, resource.data.clinicId) && request.resource.data.clinicId == resource.data.clinicId);
        allow delete: if isOwner(userId) || isAdmin() || hasClinicWriteAccess(userId, resource.data.clinicId);
      }
      // Prontuário clínico (notas, exame físico, laboratório): mesmo modelo
      // de acesso dos pacientes — dono/admin total; membro escreve, viewer lê.
      match /clinical_records/{recordId} {
        allow read: if isOwner(userId) || isAdmin() || hasClinicAccess(userId, resource.data.clinicId);
        allow create: if isOwner(userId) || isAdmin() || hasClinicWriteAccess(userId, request.resource.data.clinicId);
        allow update: if isOwner(userId) || isAdmin()
          || (hasClinicWriteAccess(userId, resource.data.clinicId) && request.resource.data.clinicId == resource.data.clinicId);
        allow delete: if isOwner(userId) || isAdmin() || hasClinicWriteAccess(userId, resource.data.clinicId);
      }

      // Demais dados da subárvore do usuário (settings, ai_usage, etc.):
      // permanecem exclusivos do dono/admin — sem acesso de equipe.
      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ---- Membros de clínica (equipe multiusuário) -------------------------
    // Doc id: `${ownerId}_${clinicId}_${memberUid}`. A CRIAÇÃO do convite é
    // feita pelo servidor (api/clinic-invite.ts, Admin SDK autenticado como o
    // dono da clínica) — não pelo cliente diretamente — para poder resolver
    // e-mail→uid e validar que quem convida é de fato dono/admin da clínica.
    match /clinic_memberships/{membershipId} {
      allow read: if isAdmin()
        || (isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.memberUid == request.auth.uid));
      // O dono pode remover um membro que ele mesmo convidou; o membro pode
      // sair por conta própria. Criação continua exclusiva do servidor.
      allow delete: if isAdmin()
        || (isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.memberUid == request.auth.uid));
      allow create, update: if false;
    }

    // ---- Collection group: settings (agregação de VMs do PACS) -------------
    // Permite ao admin rodar collectionGroup('settings') para o painel de
    // controle financeiro das VMs. Só leitura, só admin. As escritas continuam
    // regidas pela subárvore do usuário acima (dono ou admin).
    match /{path=**}/settings/{settingsId} {
      allow read: if isAdmin();
    }

    // ---- Collection group: ai_usage (contagem real de laudos por usuário) --
    // Permite ao admin rodar collectionGroup('ai_usage') para a aba Consumo
    // (laudos gerados no mês, split Lite/Pro por usuário). Só leitura, só admin.
    // As escritas continuam regidas pela subárvore do usuário (dono grava a sua).
    match /{path=**}/ai_usage/{usageId} {
      allow read: if isAdmin();
    }

    // ---- Assinaturas / planos do cliente ----------------------------------
    match /subscriptions/{subId} {
      // Dono lê a própria assinatura; admin lê/gerencia todas.
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      // Criação/exclusão só por admin (ou Admin SDK nos webhooks).
      allow create, delete: if isAdmin();
      // Atualização: admin faz tudo; o dono só pode incrementar o contador de
      // uso mensal (espelho do doc do usuário) — corrige a transação de quota
      // que antes falhava por completo (bug D2). Nenhum outro campo é editável.
      allow update: if isAdmin()
        || (isSignedIn()
            && resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['reportsUsedThisMonth', 'updatedAt'])
            && request.resource.data.get('reportsUsedThisMonth', 0)
                 >= resource.data.get('reportsUsedThisMonth', 0));
    }

    // ---- Catálogo de planos SaaS ------------------------------------------
    match /saas_plans/{planId} {
      // Catálogo público de preços — legível por qualquer visitante (vitrine de
      // planos na tela de entrada, antes do login). Não contém dado sensível.
      allow read: if true;
      allow write: if isAdmin();

      // Histórico de mudança de preço (snapshot antes/depois + quem mudou) —
      // não é público como o catálogo em si; só admin (rastreabilidade financeira).
      match /price_history/{entryId} {
        allow read, create: if isAdmin();
        allow update, delete: if false;
      }
    }

    // ---- Logs de auditoria -------------------------------------------------
    match /audit_logs/{logId} {
      // Usuário registra ações em nome próprio (sem forjar autoria); admin lê.
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ---- Tickets de suporte ------------------------------------------------
    match /support_tickets/{ticketId} {
      // Usuário cria/lê/atualiza o próprio ticket; admin gerencia todos.
      allow read, update: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();

      // Mensagens dentro do ticket: apenas o dono do ticket ou admin.
      match /{document=**} {
        allow read, write: if isAdmin()
          || (isSignedIn()
              && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid);
      }
    }

    // ---- Transações financeiras (sensível) --------------------------------
    match /transactions/{txId} {
      // Admin lê tudo; o dono lê apenas as próprias transações (histórico de
      // pagamentos no painel do usuário). A consulta precisa filtrar por userId.
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false; // somente Admin SDK (webhooks) escreve

      // Status de nota fiscal — metadado editável pelo admin, separado da
      // transação em si (que continua imutável fora do webhook).
      match /nf/{docId} {
        allow read, write: if isAdmin();
      }
    }

    // ---- Configuração global e mensagens de sistema -----------------------
    // Docs SENSÍVEIS (chave de pagamento, receita agregada) → só admin.
    // Demais docs (prompts/planos/preços que os usuários herdam) → qualquer
    // usuário autenticado. Nenhum cliente não-admin lê os sensíveis.
    match /global_config/{docId} {
      allow read: if isAdmin()
        || (isSignedIn() && !(docId in ['abacatepay_config', 'finance_stats']));
      allow write: if isAdmin();
    }

    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---- Métricas diárias agregadas (telemetria) --------------------------
    // Escritas SOMENTE pelo CRON via Admin SDK (collection-group sobre ai_usage);
    // o painel admin apenas lê.
    match /metrics_daily/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---- Ledger de despesas gerais do negócio (fora de VM/IA) -------------
    match /general_expenses/{expenseId} {
      allow read, write: if isAdmin();
    }

    // ---- Bloqueio padrão ---------------------------------------------------
    // Qualquer caminho não declarado acima é negado por omissão.
  }
}
