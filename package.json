{
  "name": "laud-us",
  "private": true,
  "version": "2.2.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "description": "LAUD.US — Sistema Profissional de Laudos Ultrassonográficos com IA",
  "scripts": {
    "sync:pacs-scripts": "node -e \"const fs=require('fs');fs.mkdirSync('public/pacs',{recursive:true});['agent.js','generate_wl.py','pacs-tenant.sh','pacs-harden.sh','pacs-vm-setup.sh','pacs-import.sh','glinet-pacs-relay.sh'].forEach(f=>fs.copyFileSync('scripts/'+f,'public/pacs/'+f));console.log('public/pacs sincronizado')\"",
    "predev": "npm run sync:pacs-scripts",
    "prebuild": "npm run sync:pacs-scripts",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --max-warnings=99999",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@sentry/react": "^10.63.0",
    "@tiptap/extension-placeholder": "^2.10.3",
    "@tiptap/extension-text-align": "^2.10.3",
    "@tiptap/extension-underline": "^2.10.3",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "docx": "^9.0.3",
    "file-saver": "^2.0.5",
    "firebase": "^12.13.0",
    "firebase-admin": "^12.7.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "pagedjs": "^0.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "workbox-window": "^7.4.1"
  }
}
