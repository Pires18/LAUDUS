{
  "functions": {
    "api/abacatepay-webhook.ts": { "maxDuration": 30 },
    "api/abacatepay-checkout.ts": { "maxDuration": 20 },
    "api/abacatepay-portal.ts": { "maxDuration": 10 },
    "api/abacatepay-cancel.ts": { "maxDuration": 20 },
    "api/abacatepay-test.ts": { "maxDuration": 15 },
    "api/reset-monthly-reports.ts": { "maxDuration": 60 },
    "api/promote-admin.ts": { "maxDuration": 15 },
    "api/anthropic.ts": { "maxDuration": 60 },
    "api/gemini.ts": { "maxDuration": 60 },
    "api/health.ts": { "maxDuration": 5 }
  },
  "crons": [
    {
      "path": "/api/reset-monthly-reports",
      "schedule": "0 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, x-webhook-signature" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
